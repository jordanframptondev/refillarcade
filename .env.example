# Production score storage (Vercel serverless functions → Upstash Redis).
# In Vercel these are injected automatically when you add Upstash Redis from
# the Storage tab — you do NOT set them by hand there. This file only documents
# them, and lets you point `vercel dev` at a Redis instance if you want to test
# the functions locally.
#
# Local `npm run dev` does NOT need these — it uses the file-based Express
# server in server/index.js.
KV_REST_API_URL=
KV_REST_API_TOKEN=
